generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // delete folder genereated lalu genereate ulang dan + src/generated/prisma
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// membuat enum field type
enum FieldType {
  text
  number
  date
  textarea
  file
}
