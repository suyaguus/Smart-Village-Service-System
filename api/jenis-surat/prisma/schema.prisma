generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model JenisSurat {
  id         Int      @id @default(autoincrement())
  nama_surat String   @db.VarChar(255)
  kode_surat String   @unique @db.VarChar(100)
  deskripsi  String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("tb_jenis_surat")
}
