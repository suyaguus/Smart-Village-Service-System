generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // delete folder genereated lalu genereate ulang dan + src/generated/prisma
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum StatusPengaduan {
  MENUNGGU
  DIPROSES
  SELESAI
}

model Pengaduan {
  id         Int             @id @default(autoincrement())
  user_id    String          @db.VarChar(50)
  judul      String          @db.VarChar(255)
  deskripsi  String          @db.Text
  status     StatusPengaduan @default(MENUNGGU)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  respon     PengaduanRespon[]

  @@map("tb_pengaduan")
}

model PengaduanRespon {
  id           Int       @id @default(autoincrement())
  pengaduan_id Int
  admin_id     String    @db.VarChar(50)
  text         String    @db.Text
  created_at   DateTime  @default(now())

  pengaduan    Pengaduan @relation(fields: [pengaduan_id], references: [id], onDelete: Cascade)

  @@map("tb_pengaduan_respon")
}